{
  "name": "agent-studio",
  "version": "0.1.2-beta.1",
  "description": "Agent Studio desktop app",
  "author": "Tiep Duong <dmtmd2010@yahoo.com.vn>",
  "main": "out/main/index.js",
  "private": true,
  "scripts": {
    "engine": "cd engine && npm run pack",
    "postinstall": "electron-rebuild -f -w node-pty",
    "predev": "npm run engine",
    "prebuild": "npm run engine",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "co.uk.wolflogic.agentstudio",
    "productName": "Agent Studio",
    "files": [
      "out/**",
      "resources/**"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "extraResources": [
      {
        "from": "engine/dist",
        "to": "engine/dist"
      },
      {
        "from": "engine/dist-pack",
        "to": "engine/dist-pack"
      },
      {
        "from": "engine/node_modules",
        "to": "engine/node_modules"
      },
      {
        "from": "engine/package.json",
        "to": "engine/package.json"
      }
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "tiepduong7c9",
      "repo": "agent-studio"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "maintainer": "Tiep Duong <dmtmd2010@yahoo.com.vn>",
      "category": "Development",
      "executableArgs": [
        "--ozone-platform-hint=wayland"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^1.23.0",
    "monaco-editor": "^0.55.1",
    "nanoid": "^5.1.16",
    "node-pty": "^1.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ssh2": "^1.16.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
